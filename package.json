{
  "name": "school-management-backend",
  "version": "1.0.0",
  "description": "School Management System Backend API with TypeScript, Zod validation, and PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "test": "jest --detectOpenHandles --forceExit --testTimeout=30000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=src/services/ --testPathIgnorePatterns=tests/",
    "test:integration": "jest --testPathPatterns=tests/integration",
    "test:api": "jest --testPathPatterns=tests/api",
    "test:api:watch": "jest --testPathPatterns=tests/api --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "db:migrate": "node dist/database/migrate.js",
    "db:migrate:dev": "ts-node src/database/migrate.ts",
    "db:seed": "ts-node src/seed-superadmin.ts",
    "start:prod": "node dist/database/migrate.js && node dist/index.js",
    "build:prod": "npm run build && npm run db:migrate",
    "typecheck": "tsc --noEmit",
    "start:worker": "node dist/workers/notificationWorker.js",
    "dev:worker": "nodemon src/workers/notificationWorker.ts",
    "start:full": "npm run db:migrate:dev && npm run dev",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report e2e/report",
    "e2e:debug": "npx playwright test --debug",
    "e2e:api": "npx playwright test e2e/tests/13-api-all-endpoints.spec.ts",
    "e2e:auth": "npx playwright test e2e/tests/01-login-flows.spec.ts",
    "seed:test-users": "ts-node e2e/seed-test-users.ts"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "postgresql",
    "zod",
    "school-management"
  ],
  "author": "Abhishek Singh",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@sentry/node": "^10.22.0",
    "@sentry/profiling-node": "^10.49.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.1.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-slow-down": "^3.0.0",
    "express-status-monitor": "^1.3.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "puppeteer": "^24.42.0",
    "redis": "^5.9.0",
    "socket.io": "^4.8.3",
    "validator": "^13.15.20",
    "xss": "^1.0.15",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-status-monitor": "^1.3.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.3",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "bcrypt": "^6.0.0",
    "eslint": "^9.30.1",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json",
          "diagnostics": false
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/types/**",
      "!src/index.ts",
      "!src/database/**"
    ],
    "coverageDirectory": "coverage",
    "verbose": true,
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup.ts"
    ],
    "testTimeout": 30000
  }
}
