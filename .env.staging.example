# =============================================================================
# School Management System — STAGING environment template
#
# Copy to .env.staging on your staging server:
#   cp .env.staging.example .env.staging
#
# Then fill in real values. NEVER commit .env.staging.
# Generate secrets: openssl rand -hex 32
# =============================================================================

NODE_ENV=staging
PORT=3000

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=EduSaaS Staging
APP_URL=https://staging.yourdomain.com
BILLING_EMAIL=billing@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com
STATUS_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres                  # Docker service name
DB_PORT=5432
DB_NAME=school_management_staging
DB_USER=school_staging
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_STAGING
JWT_EXPIRES_IN=7d
SUPER_ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_STRING_HERE_STAGING

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://staging.yourdomain.com

# ── Rate Limiting (slightly relaxed vs prod for QA ease) ─────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_STAGING
REDIS_DB=0
CACHE_TTL_SECONDS=300

# ── Email (use real SMTP or a staging sandbox like Mailtrap) ──────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_MAILTRAP_USER
SMTP_PASS=CHANGE_ME_MAILTRAP_PASS
SMTP_FROM="EduSaaS Staging <no-reply@staging.yourdomain.com>"

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx,csv,txt

# ── Sentry (staging DSN — separate project from prod for noise isolation) ─────
SENTRY_DSN=https://YOUR_STAGING_DSN@o0.ingest.sentry.io/...

# ── Integrations ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
RAZORPAY_KEY_ID=rzp_test_...          # Use TEST keys in staging
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
STRIPE_SECRET_KEY=sk_test_...         # Use TEST keys in staging
STRIPE_WEBHOOK_SECRET=whsec_...
