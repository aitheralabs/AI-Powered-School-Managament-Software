# =============================================================================
# School Management System — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# Generate strong secrets with:  openssl rand -hex 32
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development               # development | production | test
PORT=3000

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=EduSaaS                    # Platform name shown in all emails and 2FA QR codes
APP_URL=http://localhost:4200      # Public frontend URL (used in email links)
# Billing contact addresses used in dunning / invoice emails:
BILLING_EMAIL=billing@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ── Status Dashboard ──────────────────────────────────────────────────────────
# Password for the /status monitoring dashboard (HTTP Basic Auth, user = "admin")
# Leave blank in development; set a strong value in production.
STATUS_DASHBOARD_PASSWORD=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_management
DB_USER=school_admin
DB_PASSWORD=change_me_in_production         # REQUIRED

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_64_char_random_string    # REQUIRED
JWT_EXPIRES_IN=7d

# ── Super Admin JWT (separate secret for platform-level login) ─────────────────
# Generate: openssl rand -hex 32
SUPER_ADMIN_JWT_SECRET=replace_with_different_64_char_random_string  # REQUIRED in prod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production example: CORS_ORIGIN=https://school.com,https://www.school.com
CORS_ORIGIN=http://localhost:4200

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=100        # requests per window per IP

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_ENABLED=false                # Set to true when Redis is available
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                    # Leave blank for dev (no auth); set in production
REDIS_DB=0
CACHE_TTL_SECONDS=300              # Default TTL: 5 minutes

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Leave blank to disable email (fee reminders, welcome emails, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                  # true for port 465, false for 587 (STARTTLS)
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password        # Gmail: use an App Password, not your account password
SMTP_FROM="School Management <no-reply@school.com>"

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880              # 5 MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx,csv,txt

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Required for AI Insights feature (available on standard+ subscription plans)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Payment Gateways ──────────────────────────────────────────────────────────
# Razorpay (for India)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Stripe (for international)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Super Admin Seed ─────────────────────────────────────────────────────
# Used by `npm run db:seed` to create the first super-admin account.
SUPER_ADMIN_EMAIL=admin@yourschool.com
SUPER_ADMIN_PASSWORD=change_me_min_12_chars    # Min 12 chars, no defaults like "password"
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# ── Monitoring (Sentry) ───────────────────────────────────────────────────────
# Leave blank to disable Sentry error tracking
SENTRY_DSN=https://...@o0.ingest.sentry.io/...
