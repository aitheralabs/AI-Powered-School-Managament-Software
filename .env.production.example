# =============================================================================
# School Management System — PRODUCTION environment template
#
# Copy to .env on your production server:
#   cp .env.production.example .env
#
# Fill in EVERY value. Leave NOTHING as the placeholder text.
# Store the populated file in a secrets manager, NOT in git.
#
# Generate secrets:
#   openssl rand -hex 32      → JWT / DB passwords
#   openssl rand -base64 32   → shorter random strings
# =============================================================================

NODE_ENV=production
PORT=3000

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=EduSaaS
APP_URL=https://yourdomain.com          # No trailing slash
BILLING_EMAIL=billing@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com
STATUS_DASHBOARD_PASSWORD=CHANGE_ME_VERY_STRONG_PASSWORD  # /status dashboard Basic Auth

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=school_management
DB_USER=school_admin
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD_64_CHARS     # min 32 chars

# ── JWT (MUST be at least 64 chars, MUST differ between JWT and super-admin) ──
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_A
JWT_EXPIRES_IN=7d
SUPER_ADMIN_JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_B  # Different from JWT_SECRET

# ── CORS (list ALL frontend origins, comma-separated) ─────────────────────────
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100           # per IP per window

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
CACHE_TTL_SECONDS=300

# ── Email (transactional SMTP — use SendGrid / SES / Postmark for reliability) ─
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_SENDGRID_API_KEY
SMTP_FROM="EduSaaS <no-reply@yourdomain.com>"

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880               # 5 MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx,csv,txt

# ── Sentry (production DSN) ───────────────────────────────────────────────────
SENTRY_DSN=https://YOUR_PROD_DSN@o0.ingest.sentry.io/...

# ── Payment Gateways (use LIVE keys in production) ────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=CHANGE_ME_LIVE_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
