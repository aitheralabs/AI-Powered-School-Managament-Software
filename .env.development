# =============================================================================
# School Management System — DEVELOPMENT environment
#
# This file is safe to commit — it contains no real secrets.
# Override any value in a local .env.development.local (gitignored).
# =============================================================================

NODE_ENV=development
PORT=3000

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=EduSaaS Dev
APP_URL=http://localhost:4200
BILLING_EMAIL=billing@localhost
SUPPORT_EMAIL=support@localhost
STATUS_DASHBOARD_PASSWORD=

# ── Database (local Docker or host Postgres) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_management_dev
DB_USER=school_dev
DB_PASSWORD=school_dev_password

# ── JWT (short-lived for fast iteration, NOT for production) ──────────────────
JWT_SECRET=dev_jwt_secret_not_for_production_must_be_32_chars
JWT_EXPIRES_IN=7d
SUPER_ADMIN_JWT_SECRET=dev_super_admin_secret_not_for_production_32ch

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# ── Rate Limiting (relaxed in dev) ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ── Redis (disabled by default in dev, enable if you have Redis running) ──────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_SECONDS=60

# ── Email (MailHog / Mailtrap for dev — nothing real is sent) ─────────────────
# Option A: MailHog  →  docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EduSaaS Dev <no-reply@localhost>"

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx,csv,txt

# ── Integrations (all disabled in dev unless you're testing them) ─────────────
SENTRY_DSN=
ANTHROPIC_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
