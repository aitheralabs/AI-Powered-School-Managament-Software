{
  "name": "school-management-fullstack",
  "version": "1.0.0",
  "description": "School Management System - Full Stack",
  "scripts": {
    "build": "npm run build:be && npm run build:fe",
    "build:be": "cd .. && tsc",
    "build:fe": "cd school-management-frontend && ng build",
    "start": "concurrently \"npm run dev\" \"cd ../school-management-frontend && ng serve\"",
    "dev": "cd .. && npm run dev",
    "test": "node test-runner.js",
    "test:be": "node test-runner.js be",
    "test:fe": "node test-runner.js fe",
    "test:watch": "node test-runner.js watch",
    "test:coverage": "node test-runner.js coverage",
    "test:unit": "node test-runner.js unit",
    "test:integration": "node test-runner.js integration",
    "db:migrate": "cd .. && npm run db:migrate",
    "lint": "npm run lint:be && npm run lint:fe",
    "lint:be": "cd .. && npm run lint",
    "lint:fe": "cd school-management-frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
